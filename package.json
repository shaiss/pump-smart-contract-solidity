{
  "name": "pump-smart-contract-solidity",
  "version": "0.0.0-fork",
  "private": false,
  "description": "Pump-style EVM bonding curve; fork with Conduit Leo (OP Stack) tooling and gum CLI",
  "scripts": {
    "compile": "node ./scripts/run-hardhat.cjs compile",
    "deploy:leo": "node ./scripts/run-hardhat.cjs run scripts/deployLeo.ts --network leo",
    "launch:leo": "node ./scripts/run-hardhat.cjs run scripts/launchToken.ts --network leo",
    "sell:leo": "node ./scripts/run-hardhat.cjs run scripts/sellToken.ts --network leo",
    "list:leo": "node ./scripts/run-hardhat.cjs run scripts/listTokens.ts --network leo",
    "pump": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/pump-cli.ps1",
    "pump:sh": "bash ./scripts/pump-cli.sh"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "ethers": "^6.13.5",
    "hardhat": "^2.22.19"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/contracts": "^5.3.0",
    "@openzeppelin/contracts-upgradeable": "^5.3.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.0",
    "@openzeppelin/upgrades-core": "^1.43.0",
    "dotenv": "^16.5.0"
  }
}
