# Required for deploy / launch / sell on leo (or monad)
PRIVATE_KEY=

# Optional: Conduit Leo public RPC (default matches Conduit dashboard)
LEO_RPC_URL=https://rpc-leo-jqsck8sctd.t.conduit.xyz

# Optional: real Uniswap V2 Router on your chain. If unset, deploy uses MockUniswapV2Router + PlaceholderWETH.
UNISWAP_V2_ROUTER=

# launchToken.ts — also used as gum prompt defaults in scripts/pump-cli.ps1 / pump-cli.sh
TOKEN_NAME=My Meme
TOKEN_SYMBOL=MEME
# Whole ETH (not wei). 0 = create token only, no curve buy in same tx.
INITIAL_BUY_ETH=0

# sellToken.ts — amount in wei (18 decimals)
TOKEN_ADDRESS=
TOKEN_AMOUNT=
